NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
OPENAI_API_KEY=
# Optional. Model used by the Coverage Intelligence brochure extractor
# (/api/admin/coverage/brochures/[id]/extract). Defaults to gpt-4o-mini.
OPENAI_EXTRACTION_MODEL=
SUPABASE_SERVICE_ROLE_KEY=
# Server-side only. Powers /api/juice-box/gifs (search/trending) and the
# GIF-post verification fetch in /api/team-messages. NEVER prefix with
# NEXT_PUBLIC_ — the key must not reach the browser.
GIPHY_API_KEY=

# Juice Box Web Push (Pass 6) VAPID credentials. Generate once with:
#   npx web-push generate-vapid-keys
# The PUBLIC half is intentionally NEXT_PUBLIC_ — it's shipped to the
# browser so pushManager.subscribe can derive an applicationServerKey.
# The PRIVATE half stays server-side and signs each outgoing push.
# VAPID_SUBJECT must be a `mailto:` or https URL per the spec.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=

# Server-side only. Powers /api/geocode/search — the address autocomplete
# proxy used by the Add Office modal at /offices. NEVER prefix with
# NEXT_PUBLIC_; the key stays on the server so it can't be lifted from
# the browser bundle. When unset, the proxy returns the same sanitized
# "Address lookup is temporarily unavailable." 502 it returns for any
# upstream failure, so manual address entry in Add Office still works.
GEOAPIFY_API_KEY=

# Server-side only. Used by the TEMPORARY diagnostic route
# /api/cogent/test to authenticate (x-api-key header) against Cogent's
# Orders API while we inspect the response shape. NEVER prefix with
# NEXT_PUBLIC_. Safe to remove once the Cogent test route is deleted.
COGENT_API_KEY=

# Server-side only. Powers the Test-AE-only AI Assistant (Beta) proxy at
# /api/ai/chat. AGENTIC_AI_API_KEY is sent upstream as the `x-api-key`
# header; AGENTIC_AI_CHAT_URL is the full URL of the external agent's
# POST /api/integration/chat endpoint (kept in env so it can change
# without a code edit). NEVER prefix either with NEXT_PUBLIC_ — the key
# must never reach the browser; the client only ever calls /api/ai/chat.
# When unset, the proxy returns a sanitized "temporarily unavailable" 502.
# Production endpoint:
#   AGENTIC_AI_CHAT_URL=https://app.elevateh.com/api/integration/chat
AGENTIC_AI_API_KEY=
AGENTIC_AI_CHAT_URL=https://app.elevateh.com/api/integration/chat
# Optional routing fields sent to the Elevate agent. Defaults are
# customerId="test-ae" and departmentId="sales". Override here (no code change)
# while confirming which values route the agent to plan/coverage knowledge —
# e.g. departmentId of plans / coverage / product / home-warranty / support, or
# a real Elevate customer/org id for customerId. Leave blank to keep defaults.
AGENTIC_AI_CUSTOMER_ID=
AGENTIC_AI_DEPARTMENT_ID=